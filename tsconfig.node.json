{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "outDir": "dist-electron",
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "composite": true
  },
  "include": ["src/main/**/*.ts", "src/shared/**/*.ts", "vite.config.ts", "electron.vite.config.ts"]
}
